# ─────────────────────────────────────────────────────────
# AVEREXA PLACEMENT — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# All variables are validated at runtime via config/env.ts
# ─────────────────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile — CAPTCHA bot protection
# Dev test site key (always passes): 1x00000000000000000000AA
# Dev test secret  (always passes):  1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Resend — Email delivery (resend.com)
RESEND_API_KEY=

# Google Sheets — Lead capture (service account credentials)
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Google Analytics & GTM (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
